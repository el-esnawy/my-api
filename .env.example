# --- Database ---
# MongoDB connection string. The docker-compose service exposes Mongo on 27017.
MONGODB_URI="mongodb://localhost:27017/my-api"

# Redis connection string. The docker-compose service exposes Redis on 6379.
REDIS_URL="redis://localhost:6379"

# --- Auth ---
# Secret used to sign the dashboard session JWT (httpOnly cookie).
# Generate a strong value, e.g. `openssl rand -base64 48`.
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# How long a dashboard session stays valid.
SESSION_TTL="7d"

# Key used to encrypt request tokens at rest (AES-256-GCM) so their owner can
# view them again later from the dashboard. Any length is fine — it's hashed
# into a 32-byte key. Generate a strong value, e.g. `openssl rand -base64 48`.
TOKEN_ENCRYPTION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# --- Public API ---
# Per-request-window length in seconds (Redis fixed-window rate limit). The
# actual request count allowed per window is derived from the calling
# organization's plan (see lib/billing/plans.ts), not from an env var.
RATE_LIMIT_WINDOW="60"
# Deprecated — no longer read on the request path, kept only so old .env
# files don't need to change. Safe to delete.
# RATE_LIMIT_MAX="120"

# --- Email (Resend) ---
# Used to send team-invite emails. Get a free-tier key at https://resend.com.
# Without a real key, invite creation still succeeds but the email send fails
# silently (the invite can still be accepted via its accept URL, which is
# echoed back in the API response outside of production).
RESEND_API_KEY=""
# Must be a verified sending address/domain in your Resend account, or use
# Resend's shared onboarding domain for local development.
EMAIL_FROM="My API <onboarding@resend.dev>"

# Public base URL used when displaying the generated endpoint URLs in the UI,
# and to build invite accept links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
